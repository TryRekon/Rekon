{
  "name": "token-profiler",
  "version": "0.1.0",
  "private": true,
  "description": "Transparent proxy for AI provider APIs (Anthropic, OpenAI) that records per-request token usage to Cloudflare D1 and visualizes it in a React dashboard.",
  "license": "Apache-2.0",
  "author": "Tre Dubrava",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryRekon/Rekon.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web",
    "lint:design": "eslint web",
    "lint:style": "stylelint \"web/**/*.css\"",
    "verify-ui": "node scripts/verify-ui.mjs",
    "typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply token-profiler-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply token-profiler-db --remote"
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "posthog-js": "^1.400.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "openai": "^6.46.0",
    "stylelint": "^17.14.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
